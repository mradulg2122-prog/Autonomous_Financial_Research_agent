# ============================================================
# ARA-1: Autonomous Financial Research Agent
# Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ara1
POSTGRES_USER=ara1_user
POSTGRES_PASSWORD=ara1_secure_password_change_me
DATABASE_URL=postgresql+asyncpg://ara1_user:ara1_secure_password_change_me@postgres:5432/ara1

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_change_me
REDIS_DB=0
REDIS_URL=redis://:redis_secure_password_change_me@redis:6379/0
REDIS_TTL_SECONDS=3600

# ─────────────────────────────────────────
# Qdrant
# ─────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=ara1_documents
QDRANT_VECTOR_SIZE=3072

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
APP_NAME=ARA-1
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─────────────────────────────────────────
# Financial Data APIs (Optional)
# ─────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
SEC_API_KEY=

# ─────────────────────────────────────────
# Agent Configuration
# ─────────────────────────────────────────
MAX_RESEARCH_ITERATIONS=5
MAX_TOOL_CALLS_PER_AGENT=10
AGENT_TIMEOUT_SECONDS=120
PLANNER_MAX_SUBTASKS=10

# ─────────────────────────────────────────
# RAG Configuration
# ─────────────────────────────────────────
RAG_TOP_K=20
RAG_RERANK_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# ─────────────────────────────────────────
# Retry Configuration
# ─────────────────────────────────────────
MAX_RETRIES=3
RETRY_MIN_WAIT=1
RETRY_MAX_WAIT=60
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
